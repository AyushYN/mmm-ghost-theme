<article class="post-card {{post_class}} reveal">
    <a href="{{url}}" class="post-card__media">
        {{#if feature_image}}
        <img src="{{img_url feature_image size="m"}}"
             srcset="{{img_url feature_image size="s"}} 300w, {{img_url feature_image size="m"}} 600w, {{img_url feature_image size="l"}} 1000w"
             sizes="(max-width: 768px) 100vw, 380px"
             alt="{{#if feature_image_alt}}{{feature_image_alt}}{{else}}{{title}}{{/if}}" loading="lazy">
        {{else}}
        <span class="ph ph--leaf" aria-hidden="true">{{> "icon-heart"}}</span>
        {{/if}}
        {{#primary_tag}}<span class="post-card__tag">{{name}}</span>{{/primary_tag}}
    </a>
    <div class="post-card__body">
        <span class="post-card__date">{{date format="DD MMM YYYY"}}</span>
        <h3 class="post-card__title"><a href="{{url}}">{{title}}</a></h3>
        <p class="post-card__excerpt">{{excerpt words="20"}}</p>
        <a href="{{url}}" class="link-arrow">Read story {{> "icon-arrow"}}</a>
    </div>
</article>
