<footer class="site-footer">
    <div class="container footer__grid">

        <div class="footer__brand">
            <span class="footer__logo">
                {{#if @custom.logo}}<img src="{{@custom.logo}}" alt="{{@site.title}}">
                {{else}}{{#if @site.logo}}<img src="{{@site.logo}}" alt="{{@site.title}}">{{else}}<span class="footer__name">{{@site.title}}</span>{{/if}}{{/if}}
            </span>
            <p class="footer__tagline">{{@custom.footer_tagline}}</p>
            <div class="footer__social">
                {{#if @custom.facebook_url}}<a href="{{@custom.facebook_url}}" target="_blank" rel="noopener" aria-label="Facebook"><svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M14 9h3V5h-3c-2.2 0-4 1.8-4 4v2H7v4h3v7h4v-7h3l1-4h-4V9c0-.6.4-1 1-1z"/></svg></a>{{/if}}
                {{#if @custom.youtube_url}}<a href="{{@custom.youtube_url}}" target="_blank" rel="noopener" aria-label="YouTube"><svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M23 12s0-3.5-.5-5c-.3-1-1-1.7-2-2C18.5 4.5 12 4.5 12 4.5s-6.5 0-8.5.5c-1 .3-1.7 1-2 2C1 9 1 12 1 12s0 3.5.5 5c.3 1 1 1.7 2 2 2 .5 8.5.5 8.5.5s6.5 0 8.5-.5c1-.3 1.7-1 2-2 .5-1.5.5-5 .5-5zM10 15.5v-7l6 3.5-6 3.5z"/></svg></a>{{/if}}
                {{#if @custom.instagram_url}}<a href="{{@custom.instagram_url}}" target="_blank" rel="noopener" aria-label="Instagram"><svg width="18" height="18" viewBox="0 0 24 24" fill="none"><rect x="3" y="3" width="18" height="18" rx="5" stroke="currentColor" stroke-width="1.8"/><circle cx="12" cy="12" r="4" stroke="currentColor" stroke-width="1.8"/><circle cx="17.5" cy="6.5" r="1.2" fill="currentColor"/></svg></a>{{/if}}
                {{#if @custom.whatsapp_number}}<a href="https://wa.me/{{@custom.whatsapp_number}}" target="_blank" rel="noopener" aria-label="WhatsApp"><svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2a10 10 0 00-8.6 15l-1.3 4.8 5-1.3A10 10 0 1012 2zm4.4 12c-.2-.1-1.4-.7-1.6-.8-.2-.1-.4-.1-.5.1-.2.2-.6.8-.7.9-.1.1-.3.2-.5.1-1.4-.7-2.3-1.3-3.3-2.9-.2-.4.2-.4.6-1.2.1-.1 0-.3 0-.4l-.7-1.7c-.2-.5-.4-.4-.5-.4h-.5c-.2 0-.4.1-.6.3-.8.8-.9 1.9-.5 3 .5 1.4 1.5 2.6 2.9 3.7 1.9 1.4 3.2 1.3 4 1.2.5-.1 1.4-.6 1.6-1.1.2-.5.2-1 .1-1.1l-.5-.5z"/></svg></a>{{/if}}
            </div>
        </div>

        {{!-- Explore column — hardcoded reliable links that match page slugs --}}
        <div class="footer__col">
            <h4>Explore</h4>
            <ul>
                <li><a href="{{@site.url}}/">Home</a></li>
                <li><a href="{{@site.url}}/about/">About Us</a></li>
                <li><a href="{{@site.url}}/programs/">Programmes</a></li>
                <li><a href="{{@site.url}}/impact/">Our Impact</a></li>
                <li><a href="{{@site.url}}/team/">Our Team</a></li>
                <li><a href="{{@site.url}}/awards/">Awards</a></li>
                <li><a href="{{@site.url}}/contact/">Contact</a></li>
            </ul>
        </div>

        {{!-- Programmes column — CMS-driven from tag:home-programs posts.
             Each post: Title = programme name, og_title (Facebook title) = link URL.
             Falls back to tag:hash-home-programs for when internal tags are used. --}}
        {{#get "posts" filter="tag:home-programs" limit="10" order="published_at asc" as |progs|}}
        {{#unless progs}}
            {{#get "posts" filter="tag:hash-home-programs" limit="10" order="published_at asc" as |progs|}}
            {{#if progs}}
            <div class="footer__col">
                <h4>Programmes</h4>
                <ul>
                    {{#foreach progs}}
                    <li><a href="{{#if og_title}}{{og_title}}{{else}}{{@site.url}}/programs/{{/if}}">{{title}}</a></li>
                    {{/foreach}}
                </ul>
            </div>
            {{/if}}
            {{/get}}
        {{else}}
            <div class="footer__col">
                <h4>Programmes</h4>
                <ul>
                    {{#foreach progs}}
                    <li><a href="{{#if og_title}}{{og_title}}{{else}}{{@site.url}}/programs/{{/if}}">{{title}}</a></li>
                    {{/foreach}}
                </ul>
            </div>
        {{/unless}}
        {{/get}}

        <div class="footer__col footer__reach">
            <h4>Reach Us</h4>
            <ul class="footer__contact">
                {{#if @custom.contact_address_main}}<li><svg width="17" height="17" viewBox="0 0 24 24" fill="none"><path d="M12 21s7-5.5 7-11a7 7 0 10-14 0c0 5.5 7 11 7 11z" stroke="currentColor" stroke-width="1.6"/><circle cx="12" cy="10" r="2.5" stroke="currentColor" stroke-width="1.6"/></svg><span>{{@custom.contact_address_main}}</span></li>{{/if}}
                {{#if @custom.contact_phone}}<li><svg width="17" height="17" viewBox="0 0 24 24" fill="none"><path d="M5 4h3l2 5-2 1c1 2 2.5 3.5 4.5 4.5l1-2 5 2v3c0 1-1 2-2 2A16 16 0 013 6c0-1 1-2 2-2z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/></svg><a href="tel:{{@custom.contact_phone}}">{{@custom.contact_phone}}</a></li>{{/if}}
                {{#if @custom.contact_email}}<li><svg width="17" height="17" viewBox="0 0 24 24" fill="none"><rect x="3" y="5" width="18" height="14" rx="2" stroke="currentColor" stroke-width="1.6"/><path d="M3 7l9 6 9-6" stroke="currentColor" stroke-width="1.6"/></svg><a href="mailto:{{@custom.contact_email}}">{{@custom.contact_email}}</a></li>{{/if}}
            </ul>
        </div>

    </div>

    <div class="footer__bar">
        <div class="container footer__bar-inner">
            <p>&copy; {{date format="YYYY"}} {{@site.title}}. All rights reserved.</p>
            {{#if @custom.footer_reg_line}}<p class="footer__reg">{{@custom.footer_reg_line}}</p>{{/if}}
        </div>
    </div>
</footer>
