<!DOCTYPE html>
<html lang="{{@site.locale}}">
<head>
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{meta_title}}</title>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&family=Fraunces:opsz,wght@9..144,400;9..144,500;9..144,600;9..144,700&display=swap" rel="stylesheet">

    <link rel="stylesheet" type="text/css" href="{{asset "css/screen.css"}}">

    {{ghost_head}}
</head>
<body class="{{body_class}}">

    <header class="mmm-header" id="siteHeader">
        <div class="mmm-nav">
            {{!-- LEFT: nav links --}}
            <div class="mmm-nav__left" id="mmm-nav-links-wrap">
                {{navigation}}
            </div>

            {{!-- CENTER: logo --}}
            <a class="mmm-nav__logo" href="{{@site.url}}">
                {{#if @custom.logo}}<img src="{{@custom.logo}}" alt="{{@site.title}}">
                {{else}}{{#if @site.logo}}<img src="{{@site.logo}}" alt="{{@site.title}}">{{else}}<span class="mmm-logo-text">{{@site.title}}</span>{{/if}}{{/if}}
            </a>

            {{!-- RIGHT: donate + burger --}}
            <div class="mmm-nav__right">
                <a href="{{@custom.donate_cta_url}}" class="mmm-donate-btn">Donate {{> "icon-heart"}}</a>
                <button class="mmm-burger" id="mmmBurger" aria-label="Open menu">
                    <span></span><span></span><span></span>
                </button>
            </div>
        </div>
    </header>

    {{!-- Mobile menu --}}
    <div class="mmm-mobile" id="mmmMobile" aria-hidden="true">
        <div class="mmm-mobile__panel">
            <button class="mmm-mobile__close" id="mmmClose">&times;</button>
            <div class="mmm-mobile__nav">{{navigation}}</div>
            <a href="{{@custom.donate_cta_url}}" class="btn btn--accent btn--block" style="margin-top:1rem">Donate Now</a>
        </div>
    </div>

    <main id="main" class="site-main {{#is "home"}}is-home{{else}}is-inner{{/is}}">
        {{{body}}}
    </main>

    {{> "footer"}}

    {{!-- Language selector (Google Translate engine, custom UI) --}}
    <div class="lang-fab" id="langFab">
        <div class="lang-menu" id="langMenu" role="menu">
            <button data-lang="en" role="menuitem">English</button>
            <button data-lang="as" role="menuitem">&#2437;&#2488;&#2478;&#2496;&#2479;&#2492;&#2494; (Assamese)</button>
            <button data-lang="hi" role="menuitem">&#2361;&#2367;&#2344;&#2381;&#2342;&#2368; (Hindi)</button>
            <button data-lang="bn" role="menuitem">&#2476;&#2494;&#2434;&#2482;&#2494; (Bengali)</button>
        </div>
        <button class="lang-fab__btn" id="langFabBtn" aria-label="Choose language">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true"><circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="1.6"/><path d="M3 12h18M12 3c2.5 2.5 2.5 15 0 18M12 3c-2.5 2.5-2.5 15 0 18" stroke="currentColor" stroke-width="1.6"/></svg>
            <span>Language</span>
        </button>
    </div>
    <div id="google_translate_element" aria-hidden="true"></div>
    <script type="text/javascript">
        function googleTranslateElementInit(){new google.translate.TranslateElement({pageLanguage:'en',includedLanguages:'en,as,hi,bn',autoDisplay:false},'google_translate_element');}
    </script>
    <script src="https://translate.google.com/translate_a/element.js?cb=googleTranslateElementInit" defer></script>

    <script src="{{asset "js/main.js"}}" defer></script>
    {{ghost_foot}}
</body>
</html>
