{{!< default}}
{{!--
  custom-newsletters.hbs — Newsletters / Annual Reports page.
  Newsletters = posts tagged "newsletter".
    Title        = newsletter name / edition
    Excerpt      = short description shown on the card
    Feature image = cover thumbnail
    The post BODY should contain a Ghost File card (PDF upload) so clicking
    "View PDF" opens the PDF directly in the browser's built-in PDF viewer.
    Alternatively paste the PDF embed URL in the post body as a link.
--}}
{{#page}}
<header class="page-hero page-hero--image">
    <div class="page-hero__bg page-hero__bg--grad"></div>
    <span class="page-hero__scrim"></span>
    <div class="container page-hero__inner">
        <nav class="crumb"><a href="{{@site.url}}">Home</a> <span>/</span> {{title}}</nav>
        <h1>{{title}}</h1>
        {{#if custom_excerpt}}<p class="page-hero__sub">{{custom_excerpt}}</p>{{else}}<p class="page-hero__sub">Annual reports, newsletters and publications from Morigaon Mahila Mehfil.</p>{{/if}}
    </div>
</header>

{{#if content}}<section class="section"><div class="container container--narrow"><div class="prose gh-content reveal">{{content}}</div></div></section>{{/if}}

{{#get "posts" filter="tag:newsletter" limit="24" order="published_at desc" as |letters|}}
    {{#if letters}}
    <section class="section">
        <div class="container">
            <div class="shead-minimal reveal"><span class="shead-label">Publications</span><h2>Newsletters &amp; Reports</h2></div>
            <div class="nl-grid">
                {{#foreach letters}}
                <article class="nl-card reveal" tabindex="0">
                    <a href="{{url}}" class="nl-card__cover">
                        {{#if feature_image}}<img src="{{img_url feature_image size="m"}}" alt="{{title}}" loading="lazy">{{else}}<span class="nl-card__ph is-grad g-blue"><svg width="38" height="38" viewBox="0 0 24 24" fill="none"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8l-6-6zM14 2v6h6M16 13H8M16 17H8M10 9H8" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg></span>{{/if}}
                    </a>
                    <div class="nl-card__body">
                        <span class="nl-card__date">{{date format="YYYY"}}</span>
                        <h4><a href="{{url}}">{{title}}</a></h4>
                        <p>{{excerpt words="18"}}</p>
                        <a href="{{url}}" class="btn btn--outline btn--sm nl-card__view-btn">View PDF {{> "icon-arrow"}}</a>
                    </div>
                    <div class="nl-card__pdf-src" hidden>{{content}}</div>
                </article>
                {{/foreach}}
            </div>
        </div>
    </section>
    {{else}}
    <section class="section">
        <div class="container">
            <p class="empty-note">No newsletters published yet. Tag posts with <b>newsletter</b> to list them here.</p>
        </div>
    </section>
    {{/if}}
{{/get}}

{{> "cta"}}
{{/page}}
