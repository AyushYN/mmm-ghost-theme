{{!< default}}
{{#post}}
<article class="post {{post_class}}">
    <header class="post-hero">
        <div class="container container--narrow">
            <nav class="crumb"><a href="{{@site.url}}">Home</a> <span>/</span> <a href="/news/">News</a></nav>
            {{#primary_tag}}<a href="{{url}}" class="pill">{{name}}</a>{{/primary_tag}}
            <h1 class="post-hero__title">{{title}}</h1>
            {{#if custom_excerpt}}<p class="post-hero__excerpt">{{custom_excerpt}}</p>{{/if}}
            <div class="post-hero__meta">
                {{#primary_author}}<span>{{name}}</span>{{/primary_author}}
                <time datetime="{{date format="YYYY-MM-DD"}}">{{date format="DD MMM YYYY"}}</time>
                <span>{{reading_time}}</span>
            </div>
        </div>
    </header>

    {{#if feature_image}}
    <figure class="post-feature container container--narrow reveal">
        <img src="{{img_url feature_image size="xl"}}" alt="{{#if feature_image_alt}}{{feature_image_alt}}{{else}}{{title}}{{/if}}">
        {{#if feature_image_caption}}<figcaption>{{feature_image_caption}}</figcaption>{{/if}}
    </figure>
    {{/if}}

    <div class="section">
        <div class="container container--narrow">
            <div class="prose gh-content">{{content}}</div>
            {{#if tags}}<div class="post-tags">{{#foreach tags}}<a href="{{url}}" class="pill pill--soft">{{name}}</a>{{/foreach}}</div>{{/if}}
        </div>
    </div>

    {{#get "posts" filter="tag:success-stories+id:-{{id}}" limit="3" order="published_at desc" as |related|}}
        {{#if related}}
        <section class="section bg-soft">
            <div class="container">
                <div class="shead-minimal reveal"><span class="shead-label">Keep Reading</span><h2>More stories of change</h2></div>
                <div class="grid grid-3">{{#foreach related}}{{> "post-card"}}{{/foreach}}</div>
            </div>
        </section>
        {{/if}}
    {{/get}}
</article>
{{/post}}
