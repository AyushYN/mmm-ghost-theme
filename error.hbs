{{!< default}}
<section class="error-page">
    <div class="container">
        <span class="error-page__code">{{statusCode}}</span>
        <h1>{{message}}</h1>
        <p>The page you were looking for could not be found. It may have moved, or the link may be broken.</p>
        <a href="{{@site.url}}" class="btn btn--accent btn--lg">Back to Home {{> "icon-arrow"}}</a>
    </div>
</section>
