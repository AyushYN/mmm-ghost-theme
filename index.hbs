{{!< default}}
<header class="page-hero page-hero--image">
    <div class="page-hero__bg page-hero__bg--grad" aria-hidden="true"></div>
    <span class="page-hero__scrim"></span>
    <div class="container page-hero__inner">
        <nav class="crumb"><a href="{{@site.url}}">Home</a> <span>/</span> News</nav>
        <h1>News &amp; Stories</h1>
        <p class="page-hero__sub">Field notes, success stories and updates from across Morigaon and Nagaon.</p>
    </div>
</header>

<section class="section">
    <div class="container">
        {{#get "posts"
            filter="tag:-hash-internal+tag:-hero-slider+tag:-hash-hero-slider+tag:-home-stats+tag:-hash-home-stats+tag:-impact-stats+tag:-hash-impact-stats+tag:-stats+tag:-hash-stats+tag:-about-points+tag:-hash-about-points+tag:-home-programs+tag:-hash-home-programs+tag:-home-testimonials+tag:-hash-home-testimonials+tag:-home-partners+tag:-hash-home-partners+tag:-home-gallery+tag:-hash-home-gallery+tag:-gallery+tag:-hash-gallery+tag:-team-leaders+tag:-hash-team-leaders+tag:-team-board+tag:-hash-team-board+tag:-team-staff+tag:-hash-team-staff+tag:-vmg+tag:-hash-vmg+tag:-our-values+tag:-hash-our-values+tag:-milestones+tag:-hash-milestones+tag:-donate-grid+tag:-hash-donate-grid+tag:-process+tag:-hash-process+tag:-site-cta+tag:-hash-site-cta+tag:-event+tag:-newsletter+tag:-awards+tag:-get-involved"
            limit="12"
            order="published_at desc"
            as |news meta|}}
        {{#if news}}
        <div class="grid grid-3">
            {{#foreach news}}{{> "post-card"}}{{/foreach}}
        </div>
        <nav class="pagination-wrap">
            {{#if meta.pagination.prev}}<a class="btn btn--outline" href="{{page_url meta.pagination.prev}}">&larr; Newer</a>{{/if}}
            {{#if meta.pagination.next}}<a class="btn btn--outline" href="{{page_url meta.pagination.next}}">Older &rarr;</a>{{/if}}
        </nav>
        {{else}}
        <p class="empty-note">No stories have been published yet. Check back soon.</p>
        {{/if}}
        {{/get}}
    </div>
</section>
{{> "cta"}}
