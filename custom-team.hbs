{{!< default}}
{{!--
  custom-team.hbs
  Group photo = page feature image (upload the All Staff group photo here).
  Committee members = posts tagged "team-board".
  Staff = posts tagged "team-staff".
--}}
{{#page}}
<header class="page-hero page-hero--image">
    {{#if feature_image}}<div class="page-hero__bg" style="background-image:url('{{img_url feature_image size="xl"}}')"></div>{{else}}<div class="page-hero__bg page-hero__bg--grad"></div>{{/if}}
    <span class="page-hero__scrim"></span>
    <div class="container page-hero__inner">
        <nav class="crumb"><a href="{{@site.url}}">Home</a> <span>/</span> {{title}}</nav>
        <h1>{{title}}</h1>
        {{#if custom_excerpt}}<p class="page-hero__sub">{{custom_excerpt}}</p>{{else}}<p class="page-hero__sub">The committee and team who make our mission possible every day.</p>{{/if}}
    </div>
</header>

{{!-- Group photo section --}}
{{#if feature_image}}
<section class="section team-group-section">
    <div class="container">
        <div class="shead-minimal reveal"><span class="shead-label">Our Story</span></div>
        <div class="team-group-photo reveal">
            <img src="{{img_url feature_image size="xl"}}" alt="Morigaon Mahila Mehfil - Team Photo">
            {{#if content}}<div class="team-group-caption prose gh-content">{{content}}</div>{{/if}}
        </div>
    </div>
</section>
{{else}}
{{#if content}}<section class="section"><div class="container container--narrow"><div class="prose gh-content reveal">{{content}}</div></div></section>{{/if}}
{{/if}}

{{!-- FOUNDERS / LEADERS — tag:team-leaders (split card, alternating) --}}
{{#get "posts" filter="tag:hash-team-leaders" limit="10" order="published_at asc" as |leaders|}}
    {{#if leaders}}
    <section class="section">
        <div class="container">
            <div class="shead-minimal reveal"><span class="shead-label">Our Leadership</span><h2>The people who lead our mission</h2></div>
            <div class="leaders-list">
                {{#foreach leaders}}
                <article class="leader-card reveal{{#if @even}} leader-card--flip{{/if}}">
                    <div class="leader-card__photo">
                        {{#if feature_image}}<img src="{{img_url feature_image size="m"}}" alt="{{title}}">{{else}}<span class="leader-card__ph is-grad g-blue"></span>{{/if}}
                    </div>
                    <div class="leader-card__body">
                        <h3 class="leader-card__name">{{title}}</h3>
                        {{#primary_tag}}<span class="leader-card__role">{{name}}</span>{{/primary_tag}}
                        <div class="leader-card__divider"></div>
                        {{#if custom_excerpt}}<p class="leader-card__bio">{{custom_excerpt}}</p>{{else}}{{#if excerpt}}<p class="leader-card__bio">{{excerpt words="40"}}</p>{{/if}}{{/if}}
                    </div>
                </article>
                {{/foreach}}
            </div>
        </div>
    </section>
    {{/if}}
{{/get}}

{{!-- Team tabs --}}
<div class="team-tabs-bar" id="teamTabsBar">
    <div class="container">
        <div class="team-tabs">
            <button class="team-tab is-active" data-target="team-board-section" type="button">Managing Committee</button>
            <button class="team-tab" data-target="team-staff-section" type="button">Staff &amp; Field Team</button>
        </div>
    </div>
</div>

{{!-- Managing Committee --}}
{{#get "posts" filter="tag:hash-team-board" limit="50" order="published_at asc" as |board|}}
    {{#if board}}
    <section class="section bg-soft" id="team-board-section">
        <div class="container">
            <div class="shead-minimal reveal"><span class="shead-label">Leadership</span><h2>Managing Committee</h2></div>
            <div class="team-grid">
                {{#foreach board}}
                <article class="member reveal">
                    <div class="member__photo{{#unless feature_image}} is-grad{{/unless}}"{{#if feature_image}} style="background-image:url('{{img_url feature_image size="s"}}')"{{/if}}>
                        {{#unless feature_image}}<span>{{title}}</span>{{/unless}}
                    </div>
                    <h4>{{title}}</h4>
                    {{#primary_tag}}<span class="member__role">{{name}}</span>{{else}}{{#if custom_excerpt}}<span class="member__role">{{custom_excerpt}}</span>{{/if}}{{/primary_tag}}
                </article>
                {{/foreach}}
            </div>
        </div>
    </section>
    {{/if}}
{{/get}}

{{!-- Staff & Field Team --}}
{{#get "posts" filter="tag:hash-team-staff" limit="80" order="published_at asc" as |staff|}}
    {{#if staff}}
    <section class="section" id="team-staff-section">
        <div class="container">
            <div class="shead-minimal reveal"><span class="shead-label">Our People</span><h2>Staff &amp; Field Team</h2></div>
            <div class="team-grid team-grid--sm">
                {{#foreach staff}}
                <article class="member reveal">
                    <div class="member__photo{{#unless feature_image}} is-grad{{/unless}}"{{#if feature_image}} style="background-image:url('{{img_url feature_image size="s"}}')"{{/if}}>
                        {{#unless feature_image}}<span>{{title}}</span>{{/unless}}
                    </div>
                    <h4>{{title}}</h4>
                    {{#if custom_excerpt}}<span class="member__role">{{custom_excerpt}}</span>{{/if}}
                </article>
                {{/foreach}}
            </div>
        </div>
    </section>
    {{/if}}
{{/get}}

{{> "cta"}}
{{/page}}
