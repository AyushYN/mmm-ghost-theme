{{!< default}}
{{#page}}
<header class="page-hero page-hero--image">
    {{#if feature_image}}<div class="page-hero__bg" style="background-image:url('{{img_url feature_image size="xl"}}')"></div>{{else}}<div class="page-hero__bg page-hero__bg--grad"></div>{{/if}}
    <span class="page-hero__scrim"></span>
    <div class="container page-hero__inner">
        <nav class="crumb"><a href="{{@site.url}}">Home</a> <span>/</span> {{title}}</nav>
        <h1>{{title}}</h1>
        {{#if custom_excerpt}}<p class="page-hero__sub">{{custom_excerpt}}</p>{{else}}<p class="page-hero__sub">Focused programmes addressing child protection, mental health, women's empowerment, disaster response and family counselling.</p>{{/if}}
    </div>
</header>

{{#if content}}<section class="section"><div class="container container--narrow"><div class="prose gh-content reveal">{{content}}</div></div></section>{{/if}}

{{!-- Programme editorial rows â€” fully CMS-driven: posts tagged "home-programs".
     Title = programme name, Primary tag = overline label, Excerpt = description,
     Feature image = media, og_title (Facebook title) = link. Hides when no posts. --}}
{{#get "posts" filter="tag:hash-home-programs" limit="12" order="published_at asc" as |programs|}}
    {{#if programs}}
    <section class="peditorial">
        <div class="container">
            <div class="peditorial__list">
                {{#foreach programs}}
                <article class="ped-row reveal">
                    <div class="ped-row__text">
                        <span class="ped-row__num" aria-hidden="true">0{{@number}}</span>
                        <div class="ped-row__inner">
                            {{#primary_tag}}<span class="ped-row__over">{{name}}</span>{{/primary_tag}}
                            <h2 class="ped-row__title">{{title}}</h2>
                            <p class="ped-row__body">{{#if custom_excerpt}}{{custom_excerpt}}{{else}}{{excerpt words="44"}}{{/if}}</p>
                            <a href="{{#if og_title}}{{og_title}}{{else}}{{url}}{{/if}}" class="ped-link">Explore {{> "icon-arrow"}}</a>
                        </div>
                    </div>
                    <div class="ped-row__media">
                        <div class="ped-row__img{{#unless feature_image}} is-grad{{/unless}}"{{#if feature_image}} style="background-image:url('{{img_url feature_image size="l"}}')"{{/if}}></div>
                    </div>
                </article>
                {{/foreach}}
            </div>
        </div>
    </section>
    {{/if}}
{{/get}}

{{!-- PROCESS TIMELINE â€” CMS-driven: posts tagged "hash-process".
     Title = step name, Post body = step description, Primary tag = step category label.
     Add posts tagged #process in Ghost Admin to populate this section.
     Publish in order â€” publish date controls display order. --}}
{{#get "posts" filter="tag:hash-process" order="published_at asc" limit="20" as |steps|}}
    {{#if steps}}
    <section class="process-timeline-section dark-mode">
        <div class="container">
            <div class="timeline-header reveal">
                <span class="timeline-kicker">Our Process</span>
            </div>
            <div class="timeline-container">
                <div class="timeline-central-line"></div>
                {{#foreach steps}}
                <div class="timeline-item reveal">
                    <div class="timeline-node">0{{@number}}</div>
                    <div class="timeline-card glassmorphic-dark">
                        {{#primary_tag}}<div class="card-header"><span class="card-tag">{{name}}</span></div>{{/primary_tag}}
                        <h3>{{title}}</h3>
                        <div class="card-content gh-content">{{content}}</div>
                    </div>
                </div>
                {{/foreach}}
            </div>
        </div>
    </section>
    {{/if}}
{{/get}}
{{> "cta"}}
{{/page}}

